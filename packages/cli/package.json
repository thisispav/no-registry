{
  "name": "pkdns-cli",
  "version": "0.1.2",
  "description": "Manage pkdns — self-sovereign DNS on Mainline DHT",
  "type": "module",
  "bin": {
    "pkdns": "./dist/index.js"
  },
  "files": [
    "dist/index.js",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node && chmod +x dist/index.js",
    "build:binary": "bun build src/index.ts --compile --outfile pkdns-cli",
    "build:binary:all": "bun run build:binary:linux-x64 && bun run build:binary:linux-arm64 && bun run build:binary:darwin-x64 && bun run build:binary:darwin-arm64",
    "build:binary:linux-x64": "bun build src/index.ts --compile --target bun-linux-x64 --outfile dist/pkdns-linux-x64",
    "build:binary:linux-arm64": "bun build src/index.ts --compile --target bun-linux-arm64 --outfile dist/pkdns-linux-arm64",
    "build:binary:darwin-x64": "bun build src/index.ts --compile --target bun-darwin-x64 --outfile dist/pkdns-darwin-x64",
    "build:binary:darwin-arm64": "bun build src/index.ts --compile --target bun-darwin-arm64 --outfile dist/pkdns-darwin-arm64",
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build && bun run test"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@iarna/toml": "2.2.5",
    "chalk": "5.3.0",
    "commander": "12.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.4.0"
  }
}
